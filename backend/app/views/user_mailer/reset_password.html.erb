<table width="100%" cellpadding="0" cellspacing="0" style="background-color:#111111;padding:40px 16px;">
  <tr>
    <td align="center">
      <table width="100%" cellpadding="0" cellspacing="0" style="max-width:420px;background-color:#212121;border-radius:12px;padding:32px 24px;">
        <tr>
          <td align="center" style="padding-bottom:24px;">
            <span style="font-size:22px;font-weight:bold;color:#ffffff;font-family:sans-serif;">TrackRide</span>
          </td>
        </tr>
        <tr>
          <td style="font-family:sans-serif;font-size:15px;color:#656565;line-height:1.6;">
            <p style="margin:0 0 16px;">Olá, <strong style="color:#ffffff;"><%= @user.name %></strong>!</p>
            <p style="margin:0 0 16px;">Recebemos uma solicitação para redefinir sua senha.</p>
          </td>
        </tr>
        <tr>
          <td align="center" style="padding:24px 0;">
            <a href="<%= @reset_url %>" style="display:inline-block;background-color:#076fef;color:#ffffff;font-family:sans-serif;font-size:15px;font-weight:600;text-decoration:none;padding:14px 32px;border-radius:8px;">
              Redefinir senha
            </a>
          </td>
        </tr>
        <tr>
          <td style="font-family:sans-serif;font-size:13px;color:#656565;line-height:1.5;">
            <p style="margin:0 0 8px;">Este link expira em 2 horas.</p>
            <p style="margin:0;">Se você não solicitou isso, ignore este email.</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
