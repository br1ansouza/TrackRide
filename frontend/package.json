{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:standalone": "VITE_STANDALONE=1 vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"cap:sync": "npm run build:standalone && npx cap sync android && find android/app/src/main/assets/public -name '*.gz' -delete",
		"cap:build": "npm run cap:sync && cd android && ./gradlew assembleDebug"
	},
	"devDependencies": {
		"@capacitor/cli": "^6.2.0",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.2.2",
		"typescript": "^7.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@capacitor-community/background-geolocation": "^1.2.26",
		"@capacitor/android": "^6.2.0",
		"@capacitor/core": "^6.2.0",
		"@capacitor/geolocation": "^6.0.1",
		"@capacitor/haptics": "^6.0.3",
		"@capacitor/local-notifications": "^6.1.3",
		"@capacitor/status-bar": "^6.0.3",
		"@hugotomazi/capacitor-navigation-bar": "^4.0.1",
		"@tanstack/svelte-query": "^6.1.16",
		"lucide-svelte": "^1.0.1",
		"maplibre-gl": "^4.7.1",
		"zod": "^4.3.6"
	}
}
